<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Edit Product - Product Manager</title>
  <link rel="stylesheet" href="/css/product-form.css">
</head>
<body>
  <div class="form-box">
    <h1> Edit Product</h1>
    <% if (error) { %>
      <div class="error"><%= error %></div>
    <% } %>
    <form action="/product/edit/<%= product._id %>" method="POST" enctype="multipart/form-data">
      <label>Product Name</label>
      <input type="text" name="name" value="<%= product.name %>" required>

      <label>Price (₹)</label>
      <input type="number" name="price" value="<%= product.price %>" step="0.01" required>

      <label>Quantity</label>
      <input type="number" name="quantity" value="<%= product.quantity %>" required>

      <label>Manufactured Date</label>
      <input type="date" name="manufacturedDate" value="<%= new Date(product.mfgDate).toISOString().split('T')[0] %>" required>

      <label>Product Image</label>
      <% if (product.imageUrl) { %>
        <div class="current-img">
          <p>Current Image:</p>
          <img src="<%= product.imageUrl %>" alt="<%= product.name %>">
        </div>
      <% } %>
      <input type="file" name="image" accept="image/*">

      <div class="buttons">
        <button type="submit" class="update-btn">Update Product</button>
        <a href="/" class="btn-cancel">Cancel</a>
      </div>
    </form>
  </div>
</body>
</html>

